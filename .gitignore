.idea/
.vscode/
*.swp
*.swo
.DS_Store
local*

# Ignore any file or directory with 'venv' in the name
*venv*
*venv*/
venv/
venv2/

#ignore cache
*.pyc

#explicitly ignore our cft and genrm datasets as they are simply too big
# Ignore all JSON files containing 'cft' anywhere in their name
# need to download these using the tools/scripts provided
*cft*.json
*CFT*.json
*genrm*.json

#ignore the backup folder
.git_backup
.git_backup/
clean/

# Ignore all FILES in checkpoint directories
# this is NOT THE SAME as ignoring the entire directory completely
# this is finding a directory and ignoring FILES inside the directory
# this allows us to ignore stuff in a directory EXCEPT for a few files
# note that we need to use absolute filepaths here for the start so *output*/**/*.png doesnt work
train/LLaMA-Factory/output_models/**/*
# this un-ignores the directories themselves (this keeps the directory structure)
!train/LLaMA-Factory/output_models/**/*/
# And don't ignore PNG files
!train/LLaMA-Factory/output_models/**/*.png
#dont ignore logs and state files
!train/LLaMA-Factory/output_models/**/*log*
!train/LLaMA-Factory/output_models/**/*state*
!train/LLaMA-Factory/output_models/**/*result*

#for these folders, they exist and are modified on the HPC, I dont want to transfer them
bitsandbytes/
train/LLaMA-Factory/xformers/
#ignore .save backups generated by the SGE
*.save
#ignore log files created by hpc
*.o[0-9]

